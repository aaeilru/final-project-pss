# =============================================================================
# Simple LMS - Environment Variables
# =============================================================================

# --- Django ---
SECRET_KEY=ganti-dengan-secret-key-acak-yang-panjang
DEBUG=True
ALLOWED_HOSTS=*

# --- PostgreSQL ---
POSTGRES_DB=simple_lms
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=ganti-password-postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=ganti-password-mongo
MONGO_DB_NAME=lms_analytics

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=lms_admin
RABBITMQ_DEFAULT_PASS=ganti-password-rabbitmq